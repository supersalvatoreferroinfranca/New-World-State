# Database Configuration
DATABASE_URL=

# Configurazione Aruba SMTP (o qualsiasi altro provider SMTP)
# -------------------------------------------------------------
# Host SMTP di Aruba (generalmente smtps.aruba.it per SSL su porta 465, oppure smtp.aruba.it)
SMTP_HOST=smtps.aruba.it

# Porta SMTP: 465 (consigliata per SSL sicuro) oppure 587 (per STARTTLS)
SMTP_PORT=465

# Imposta a true se usi la porta 465 (SSL). Imposta a false se usi 587 o 25
SMTP_SECURE=true

# Il tuo indirizzo email completo Aruba (es. info@tuodominio.it o anagrafe@newworldstate.cloud)
SMTP_USER=

# La password del tuo indirizzo email Aruba
SMTP_PASS=

# L'indirizzo email mittente (solitamente coincide con SMTP_USER)
SMTP_FROM=

# Nome visualizzato dal mittente (es. Anagrafe New World State)
SMTP_FROM_NAME=Anagrafe New World State

# Email dell'Amministratore che riceve le notifiche di nuova registrazione
ADMIN_EMAIL=supersalvatoreferroinfranca@gmail.com

# Configurazione Aruba Uploader Bridge (Salvataggio Fisico Documenti Certificati su Hosting Aruba)
# ------------------------------------------------------------------------------------------------
# L'indirizzo URL del file PHP caricato tramite FTP sul tuo hosting Aruba (es. https://tuodominio.it/nws-uploader.php)
ARUBA_UPLOADER_URL=

# Una chiave segreta personalizzata generata da te per proteggere ed autorizzare le richieste da Cloudflare ad Aruba
ARUBA_UPLOADER_KEY=

# Google Gemini API Key for AI Legislative drafting assistant
GEMINI_API_KEY=

