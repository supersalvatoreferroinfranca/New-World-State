{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "newworldstate",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "DATABASE_URL": ""
  }
}
